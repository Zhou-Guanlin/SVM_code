def export_rep_norm_points(method_dir: Path, method: str, rep_eval: int, X_all_norm: np.ndarray,
                           y: np.ndarray, rep_train_idx: np.ndarray, rep_test_idx: np.ndarray):
    out_sub = method_dir / "rep_export"
    out_sub.mkdir(parents=True, exist_ok=True)
    X_all_norm = np.asarray(X_all_norm)
    y = np.asarray(y).astype(int)
    split = np.array(["other"] * len(y), dtype=object)
    split[rep_train_idx] = "train"; split[rep_test_idx] = "test"

    df_all = pd.DataFrame({"x1": X_all_norm[:, 0], "x2": X_all_norm[:, 1], "x3": X_all_norm[:, 2],
                           "label": y, "split": split})
    df_train = df_all[df_all["split"] == "train"].copy()
    df_test = df_all[df_all["split"] == "test"].copy()
    f_all = out_sub / f"{STEM}_{method}_repEval{rep_eval}_all_norm_points.csv"
    f_tr = out_sub / f"{STEM}_{method}_repEval{rep_eval}_train_norm_points.csv"
    f_te = out_sub / f"{STEM}_{method}_repEval{rep_eval}_test_norm_points.csv"
    safe_to_csv(df_all, f_all); safe_to_csv(df_train, f_tr); safe_to_csv(df_test, f_te)
    print(f"[Saved] rep normalized points (ALL)  -> {f_all}")
    print(f"[Saved] rep normalized points (TRAIN)-> {f_tr}")
    print(f"[Saved] rep normalized points (TEST) -> {f_te}")
    return out_sub

def export_decision_planes_xyz(method_dir: Path, method: str, rep_eval: int, model, X_all_norm: np.ndarray, grid_n: int = 80):
    out_sub = method_dir / "rep_export"
    out_sub.mkdir(parents=True, exist_ok=True)
    X_all_norm = np.asarray(X_all_norm)
    xlim = _axis_limits_with_margin(X_all_norm[:, 0])
    ylim = _axis_limits_with_margin(X_all_norm[:, 1])
    zlim = _axis_limits_with_margin(X_all_norm[:, 2])
    w = model.coef_.ravel(); b = float(model.intercept_.ravel()[0])
    solve_idx = int(np.argmax(np.abs(w)))
    grid_idx = [i for i in range(3) if i != solve_idx]
    lims = [xlim, ylim, zlim]
    u_lim = lims[grid_idx[0]]; v_lim = lims[grid_idx[1]]
    U, V = np.meshgrid(np.linspace(u_lim[0], u_lim[1], grid_n), np.linspace(v_lim[0], v_lim[1], grid_n))
    ws = w[solve_idx]
    if abs(ws) < EPS:
        raise RuntimeError("export_decision_planes_xyz: ws is too small to solve the plane stably.")

    def solve_to_xyz(level: float):
        Suv = (level - (w[grid_idx[0]] * U + w[grid_idx[1]] * V) - b) / ws
        coords = [None, None, None]
        coords[grid_idx[0]] = U; coords[grid_idx[1]] = V; coords[solve_idx] = Suv
        Xs, Ys, Zs = coords[0], coords[1], coords[2]
        mask = ((Xs >= xlim[0]) & (Xs <= xlim[1]) & (Ys >= ylim[0]) & (Ys <= ylim[1]) &
                (Zs >= zlim[0]) & (Zs <= zlim[1]) & np.isfinite(Xs) & np.isfinite(Ys) & np.isfinite(Zs))
        return np.c_[Xs[mask].ravel(), Ys[mask].ravel(), Zs[mask].ravel()]

    for tag, lvl in {"0":0.0, "pos1":1.0, "neg1":-1.0}.items():
        xyz = solve_to_xyz(lvl)
        df = pd.DataFrame({"x": xyz[:, 0], "y": xyz[:, 1], "z": xyz[:, 2]})
        out_csv = out_sub / f"{STEM}_{method}_repEval{rep_eval}_plane_level_{tag}.csv"
        safe_to_csv(df, out_csv)
        print(f"[Saved] decision plane xyz (level={lvl:+.0f}) -> {out_csv}   (n={len(df)})")

    meta = {
        "stem": STEM, "method": method, "rep_eval": int(rep_eval), "grid_n": int(grid_n),
        "xlim": [float(xlim[0]), float(xlim[1])], "ylim": [float(ylim[0]), float(ylim[1])],
        "zlim": [float(zlim[0]), float(zlim[1])], "solve_idx": int(solve_idx),
        "grid_idx": [int(grid_idx[0]), int(grid_idx[1])]
    }
    meta_path = out_sub / f"{STEM}_{method}_repEval{rep_eval}_plane_meta.json"
    meta_path.write_text(json.dumps(meta, indent=2, ensure_ascii=False), encoding="utf-8")
    print(f"[Saved] plane meta -> {meta_path}")

