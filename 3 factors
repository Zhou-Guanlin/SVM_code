def safe_to_csv(df: pd.DataFrame, out_csv: Path):
    try:
        df.to_csv(out_csv, index=False, encoding="utf-8-sig")
        return out_csv
    except PermissionError:
        ts = datetime.now().strftime("%Y%m%d_%H%M%S")
        alt = out_csv.with_name(out_csv.stem + f"_{ts}" + out_csv.suffix)
        df.to_csv(alt, index=False, encoding="utf-8-sig")
        return alt

def normalize_by_train_stats(X_train, X_test, method: str, y_train=None):
    
    if y_train is None:
        raise ValueError("y_train is required for normalization using the 0h class in the training set")

    y_train = np.asarray(y_train)
    mask_0h = (y_train == 1)
    if np.sum(mask_0h) == 0:
        raise ValueError("No label=1 samples were found in the current training fold")

    X_base = X_train[mask_0h]
    mean = X_base.mean(axis=0)
    var = X_base.var(axis=0, ddof=1)
    std = np.sqrt(np.maximum(var, 0.0))

    if method == "meanDiv":
        denom = np.where(np.abs(mean) < EPS, 1.0, mean)
        X_train_n = X_train / denom
        X_test_n = X_test / denom
    elif method == "zscore":
        denom = np.where(std < EPS, 1.0, std)
        X_train_n = (X_train - mean) / denom
        X_test_n = (X_test - mean) / denom
    else:
        raise ValueError("method must be 'meanDiv' or 'zscore'")

    return X_train_n, X_test_n, mean, var

def normalize_self_by_own_0h(X_raw, y_raw, method: str):
    
    y_raw = np.asarray(y_raw)
    mask_0h = (y_raw == 1)
    if np.sum(mask_0h) == 0:
        raise ValueError("No label=1 samples were found in the external data")

    X_base = X_raw[mask_0h]
    mean = X_base.mean(axis=0)
    var = X_base.var(axis=0, ddof=1)
    std = np.sqrt(np.maximum(var, 0.0))

    if method == "meanDiv":
        denom = np.where(np.abs(mean) < EPS, 1.0, mean)
        X_norm = X_raw / denom
    elif method == "zscore":
        denom = np.where(std < EPS, 1.0, std)
        X_norm = (X_raw - mean) / denom
    else:
        raise ValueError("method must be 'meanDiv' or 'zscore'")
    return X_norm, mean, var

def _axis_limits_with_margin(vec, margin_ratio=0.05):
    lo, hi = float(np.min(vec)), float(np.max(vec))
    span = hi - lo
    m = span * margin_ratio if span > 0 else 1.0
    return (lo - m, hi + m)

def set_inner_five_ticks(ax, inner_low=0.03, inner_high=0.97):
    xmin, xmax = ax.get_xlim(); ymin, ymax = ax.get_ylim()
    xr = xmax - xmin; yr = ymax - ymin
    xticks = np.linspace(xmin + inner_low * xr, xmin + inner_high * xr, 5)
    yticks = np.linspace(ymin + inner_low * yr, ymin + inner_high * yr, 5)
    ax.xaxis.set_major_locator(FixedLocator(xticks))
    ax.yaxis.set_major_locator(FixedLocator(yticks))
    ax.xaxis.set_major_formatter(FormatStrFormatter('%.2f'))
    ax.yaxis.set_major_formatter(FormatStrFormatter('%.2f'))

def _build_supervised_projection(X_ref, model):
    
    w = model.coef_.ravel().astype(float)
    w_norm = np.linalg.norm(w)
    if w_norm < EPS:
        raise RuntimeError("Supervised projection failed: SVM normal vector norm is too small.")

    e1 = w / w_norm
    origin = np.mean(np.asarray(X_ref, dtype=float), axis=0)

    
    Xc = np.asarray(X_ref, dtype=float) - origin
    X_plane = Xc - np.outer(Xc @ e1, e1)

    if np.allclose(X_plane, 0.0, atol=1e-10):
        
        basis_pool = np.eye(X_ref.shape[1], dtype=float)
        best_vec = None
        best_norm = -1.0
        for v in basis_pool:
            v_ortho = v - np.dot(v, e1) * e1
            nrm = np.linalg.norm(v_ortho)
            if nrm > best_norm:
                best_norm = nrm
                best_vec = v_ortho
        if best_vec is None or best_norm < EPS:
            raise RuntimeError("Supervised projection failed: unable to construct the second axis.")
        e2 = best_vec / best_norm
    else:
        
        pca_in_plane = PCA(n_components=1, random_state=0)
        pca_in_plane.fit(X_plane)
        e2 = pca_in_plane.components_[0].astype(float)
        e2 = e2 - np.dot(e2, e1) * e1
        e2_norm = np.linalg.norm(e2)
        if e2_norm < EPS:
            raise RuntimeError("Supervised projection failed: second-axis normalization failed.")
        e2 = e2 / e2_norm

    return {
        "origin": origin,
        "e1": e1,
        "e2": e2,
        "w": w,
        "b": float(model.intercept_.ravel()[0]),
        "w_norm": float(w_norm),
    }

def _supervised_project(X, proj):
    X = np.asarray(X, dtype=float)
    Xc = X - proj["origin"]
    u = Xc @ proj["e1"]
    v = Xc @ proj["e2"]
    return np.c_[u, v]

def _decision_line_x(level, proj):
    
    return (level - (np.dot(proj["w"], proj["origin"]) + proj["b"])) / proj["w_norm"]

def prepare_shared_pca_and_limits(X_train_for_pca, X_old_norm, X_new_norm=None, model=None):
    if model is None:
        raise ValueError("model is required to construct the supervised projection.")

    proj = _build_supervised_projection(X_train_for_pca, model)
    X2_old = _supervised_project(X_old_norm, proj)
    if X_new_norm is not None:
        X2_new = _supervised_project(X_new_norm, proj)
        X2_comb = np.vstack([X2_old, X2_new])
    else:
        X2_new = None
        X2_comb = X2_old

    xlim = _axis_limits_with_margin(X2_comb[:, 0])
    ylim = _axis_limits_with_margin(X2_comb[:, 1])
    return proj, X2_old, X2_new, xlim, ylim

def plot_representative_split_2d_pca(X_all_norm, y, train_idx, test_idx, model, pca, xlim, ylim,
                                     out_tif: Path, pc1_label=PC1_LABEL, pc2_label=PC2_LABEL):
    X_train, y_train = X_all_norm[train_idx], y[train_idx]
    X_test, y_test = X_all_norm[test_idx], y[test_idx]
    X2_all = _supervised_project(X_all_norm, pca)
    X2_train = X2_all[train_idx]
    X2_test = X2_all[test_idx]

    fig = plt.figure(figsize=(10, 8), dpi=300)
    ax = plt.gca()
    ax.set_xlim(xlim); ax.set_ylim(ylim)
    ax.scatter(X2_train[:, 0], X2_train[:, 1], c=y_train, cmap='bwr', vmin=1, vmax=2,
               s=400, alpha=0.6, edgecolors='k', linewidths=1.5, antialiased=True)
    for cls, color in [(1, 'blue'), (2, 'red')]:
        m = (y_test == cls)
        ax.scatter(X2_test[m, 0], X2_test[m, 1], facecolors='none', edgecolors=color,
                   s=520, linewidths=2.4, marker='o', antialiased=True)

    for level, ls in zip([-1, 0, 1], ['--', '-', '--']):
        x0 = _decision_line_x(level, pca)
        ax.plot([x0, x0], [ylim[0], ylim[1]], color='k', linestyle=ls, alpha=0.7)

    ax.set_xlabel(pc1_label); ax.set_ylabel(pc2_label)
    set_inner_five_ticks(ax, inner_low=0.03, inner_high=0.97)
    plt.tight_layout(pad=0.5)
    fig.savefig(out_tif, format='tif', bbox_inches='tight')
    plt.close(fig)

def plot_newdata_on_old_boundary_2d_pca(X_new_norm, y_new, model, pca, xlim, ylim,
