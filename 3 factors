    lims = [xlim, ylim, zlim]
    u_lim = lims[grid_idx[0]]; v_lim = lims[grid_idx[1]]
    U, V = np.meshgrid(np.linspace(u_lim[0], u_lim[1], grid_n), np.linspace(v_lim[0], v_lim[1], grid_n))
    ws = w[solve_idx]
    if abs(ws) < EPS:
        raise RuntimeError("export_origin_summary_csv: ws is too small to solve the plane stably.")

    def solve_plane_xyz(level: float):
        Suv = (level - (w[grid_idx[0]] * U + w[grid_idx[1]] * V) - b) / ws
        coords = [None, None, None]
        coords[grid_idx[0]] = U; coords[grid_idx[1]] = V; coords[solve_idx] = Suv
        Xs, Ys, Zs = coords[0], coords[1], coords[2]
        mask = ((Xs >= xlim[0]) & (Xs <= xlim[1]) & (Ys >= ylim[0]) & (Ys <= ylim[1]) &
                (Zs >= zlim[0]) & (Zs <= zlim[1]) & np.isfinite(Xs) & np.isfinite(Ys) & np.isfinite(Zs))
        return np.c_[Xs[mask].ravel(), Ys[mask].ravel(), Zs[mask].ravel()]

    plane0 = solve_plane_xyz(0.0)
    plane_p1 = solve_plane_xyz(1.0)
    plane_n1 = solve_plane_xyz(-1.0)
    X_train = X_all_norm[rep_train_idx]; y_train = y[rep_train_idx]
    X_test = X_all_norm[rep_test_idx]; y_test = y[rep_test_idx]
    train_label1 = X_train[y_train == 1]
    train_label2 = X_train[y_train == 2]
    test_label1 = X_test[y_test == 1]
    test_label2 = X_test[y_test == 2]

    max_len = max(len(plane0), len(plane_p1), len(plane_n1), len(train_label1), len(train_label2), len(test_label1), len(test_label2))

    def pad_xyz(arr, n_rows):
        arr = np.asarray(arr, dtype=float)
        out = np.full((n_rows, 3), np.nan, dtype=float)
        if arr.size != 0:
            out[:len(arr), :] = arr[:, :3]
        return out

    p0 = pad_xyz(plane0, max_len); pp = pad_xyz(plane_p1, max_len); pn = pad_xyz(plane_n1, max_len)
    tr1 = pad_xyz(train_label1, max_len); tr2 = pad_xyz(train_label2, max_len)
    te1 = pad_xyz(test_label1, max_len); te2 = pad_xyz(test_label2, max_len)

    df_sum = pd.DataFrame({
        "plane0_x": p0[:, 0], "plane0_y": p0[:, 1], "plane0_z": p0[:, 2],
        "plane_pos1_x": pp[:, 0], "plane_pos1_y": pp[:, 1], "plane_pos1_z": pp[:, 2],
        "plane_neg1_x": pn[:, 0], "plane_neg1_y": pn[:, 1], "plane_neg1_z": pn[:, 2],
        "train_label1_x": tr1[:, 0], "train_label1_y": tr1[:, 1], "train_label1_z": tr1[:, 2],
        "train_label2_x": tr2[:, 0], "train_label2_y": tr2[:, 1], "train_label2_z": tr2[:, 2],
        "test_label1_x": te1[:, 0], "test_label1_y": te1[:, 1], "test_label1_z": te1[:, 2],
        "test_label2_x": te2[:, 0], "test_label2_y": te2[:, 1], "test_label2_z": te2[:, 2],
    })
    out_csv = out_sub / f"{STEM}_{method}_repEval{rep_eval}_origin_summary_xyz.csv"
    saved = safe_to_csv(df_sum, out_csv)
    print(f"[Saved] origin summary xyz CSV -> {saved}")
    return saved

def export_origin_summary_csv_new(method_dir: Path, method: str, rep_eval: int, model, axis_ref_X: np.ndarray,
                                  X_new_norm: np.ndarray, y_new: np.ndarray, y_new_pred: np.ndarray,
                                  grid_n: int = 80):
    out_sub = method_dir / "rep_export"
    out_sub.mkdir(parents=True, exist_ok=True)
    axis_ref_X = np.asarray(axis_ref_X, dtype=float)
    X_new_norm = np.asarray(X_new_norm, dtype=float)
    y_new = np.asarray(y_new).astype(int)
    y_new_pred = np.asarray(y_new_pred).astype(int)

    xlim = _axis_limits_with_margin(axis_ref_X[:, 0])
    ylim = _axis_limits_with_margin(axis_ref_X[:, 1])
    zlim = _axis_limits_with_margin(axis_ref_X[:, 2])
    w = model.coef_.ravel(); b = float(model.intercept_.ravel()[0])
    solve_idx = int(np.argmax(np.abs(w)))
    grid_idx = [i for i in range(3) if i != solve_idx]
    lims = [xlim, ylim, zlim]
    u_lim = lims[grid_idx[0]]; v_lim = lims[grid_idx[1]]
    U, V = np.meshgrid(np.linspace(u_lim[0], u_lim[1], grid_n), np.linspace(v_lim[0], v_lim[1], grid_n))
    ws = w[solve_idx]
    if abs(ws) < EPS:
        raise RuntimeError("export_origin_summary_csv_new: ws is too small to solve the plane stably.")

    def solve_plane_xyz(level: float):
        Suv = (level - (w[grid_idx[0]] * U + w[grid_idx[1]] * V) - b) / ws
        coords = [None, None, None]
        coords[grid_idx[0]] = U; coords[grid_idx[1]] = V; coords[solve_idx] = Suv
        Xs, Ys, Zs = coords[0], coords[1], coords[2]
        mask = ((Xs >= xlim[0]) & (Xs <= xlim[1]) & (Ys >= ylim[0]) & (Ys <= ylim[1]) &
                (Zs >= zlim[0]) & (Zs <= zlim[1]) & np.isfinite(Xs) & np.isfinite(Ys) & np.isfinite(Zs))
        return np.c_[Xs[mask].ravel(), Ys[mask].ravel(), Zs[mask].ravel()]

    plane0 = solve_plane_xyz(0.0)
    plane_p1 = solve_plane_xyz(1.0)
    plane_n1 = solve_plane_xyz(-1.0)
    g1c = X_new_norm[(y_new == 1) & (y_new_pred == 1)]
    g2c = X_new_norm[(y_new == 2) & (y_new_pred == 2)]
    g1w = X_new_norm[(y_new == 1) & (y_new_pred != 1)]
    g2w = X_new_norm[(y_new == 2) & (y_new_pred != 2)]

    max_len = max(len(plane0), len(plane_p1), len(plane_n1), len(g1c), len(g2c), len(g1w), len(g2w))

    def pad_xyz(arr, n_rows):
        arr = np.asarray(arr, dtype=float)
        out = np.full((n_rows, 3), np.nan, dtype=float)
        if arr.size != 0:
            out[:len(arr), :] = arr[:, :3]
        return out

    p0 = pad_xyz(plane0, max_len); pp = pad_xyz(plane_p1, max_len); pn = pad_xyz(plane_n1, max_len)
    a = pad_xyz(g1c, max_len); b2 = pad_xyz(g2c, max_len); c = pad_xyz(g1w, max_len); d = pad_xyz(g2w, max_len)

    df_sum = pd.DataFrame({
        "plane0_x": p0[:, 0], "plane0_y": p0[:, 1], "plane0_z": p0[:, 2],
        "plane_pos1_x": pp[:, 0], "plane_pos1_y": pp[:, 1], "plane_pos1_z": pp[:, 2],
        "plane_neg1_x": pn[:, 0], "plane_neg1_y": pn[:, 1], "plane_neg1_z": pn[:, 2],
        "new_true1_correct_x": a[:, 0], "new_true1_correct_y": a[:, 1], "new_true1_correct_z": a[:, 2],
        "new_true2_correct_x": b2[:, 0], "new_true2_correct_y": b2[:, 1], "new_true2_correct_z": b2[:, 2],
        "new_true1_wrong_x": c[:, 0], "new_true1_wrong_y": c[:, 1], "new_true1_wrong_z": c[:, 2],
        "new_true2_wrong_x": d[:, 0], "new_true2_wrong_y": d[:, 1], "new_true2_wrong_z": d[:, 2],
    })
    out_csv = out_sub / f"{NEW_STEM}_{method}_repEval{rep_eval}_origin_summary_xyz.csv"
    saved = safe_to_csv(df_sum, out_csv)
    print(f"[Saved] NEW origin summary xyz CSV -> {saved}")
    return saved

def run_one_normalization(X, y, method: str, method_dir: Path):
    method_dir.mkdir(parents=True, exist_ok=True)
    cv = RepeatedStratifiedKFold(n_splits=N_SPLITS, n_repeats=N_REPEATS, random_state=SEED)
    n_eval = N_SPLITS * N_REPEATS
    acc1_test = np.empty(n_eval); acc2_test = np.empty(n_eval); acc_all_test = np.empty(n_eval)
    acc1_train = np.empty(n_eval); acc2_train = np.empty(n_eval); acc_all_train = np.empty(n_eval)
    cm_test_total = np.zeros((2, 2), dtype=int); cm_train_total = np.zeros((2, 2), dtype=int)
    splits = []; rep_ids = np.empty(n_eval, dtype=int); fold_ids = np.empty(n_eval, dtype=int)

    eval_i = 0
    for split_i, (train_idx, test_idx) in enumerate(cv.split(X, y)):
        rep_id = split_i // N_SPLITS; fold_id = split_i % N_SPLITS
        X_tr_raw = X[train_idx]; X_te_raw = X[test_idx]
        y_tr = y[train_idx]; y_te = y[test_idx]
        X_tr, X_te, _, _ = normalize_by_train_stats(X_tr_raw, X_te_raw, method, y_tr)
        model = train_svm(X_tr, y_tr)

        pred_test = model.predict(X_te)
        cm_test_total += confusion_2x2_counts(y_te, pred_test)
        m1t = (y_te == 1); m2t = (y_te == 2)
        acc1_test[eval_i] = (pred_test[m1t] == y_te[m1t]).mean()
        acc2_test[eval_i] = (pred_test[m2t] == y_te[m2t]).mean()
        acc_all_test[eval_i] = (pred_test == y_te).mean()

        pred_train = model.predict(X_tr)
        cm_train_total += confusion_2x2_counts(y_tr, pred_train)
        m1r = (y_tr == 1); m2r = (y_tr == 2)
        acc1_train[eval_i] = (pred_train[m1r] == y_tr[m1r]).mean()
        acc2_train[eval_i] = (pred_train[m2r] == y_tr[m2r]).mean()
        acc_all_train[eval_i] = (pred_train == y_tr).mean()

        splits.append((train_idx, test_idx)); rep_ids[eval_i] = rep_id; fold_ids[eval_i] = fold_id; eval_i += 1

    print("\n============================================================")
    print(f"Normalization: {method}")
    print("========== Repeated Stratified 4-fold CV statistics (accuracy only) ==========")
    print(f"DATA_FILE: {DATA_FILE.name}")
    print(f"OUT_DIR: {method_dir.resolve()}")
    print(f"n_splits={N_SPLITS}, n_repeats={N_REPEATS}, total_evals={n_eval}, SEED={SEED}\n")
    print("----- Test set accuracy (across all folds & repeats) -----")
    print("Class 1 test accuracy:", summarize(acc1_test))
    print("Class 2 test accuracy:", summarize(acc2_test))
    print("Overall test accuracy:", summarize(acc_all_test))
    print("\n----- Train set accuracy (across all folds & repeats) -----")
    print("Class 1 train accuracy:", summarize(acc1_train))
    print("Class 2 train accuracy:", summarize(acc2_train))
    print("Overall train accuracy:", summarize(acc_all_train))

    print("\n========== Aggregated Confusion Matrix (across all folds & repeats) ==========")
    print("TEST (counts):\n", cm_test_total)
    print("TRAIN (counts):\n", cm_train_total)
    cm_test_row = cm_test_total / cm_test_total.sum(axis=1, keepdims=True)
    cm_train_row = cm_train_total / cm_train_total.sum(axis=1, keepdims=True)
    print("\nTEST (row-normalized, %):\n", np.round(cm_test_row * 100, 2))
    print("TRAIN (row-normalized, %):\n", np.round(cm_train_row * 100, 2))

    cm_out_csv = method_dir / f"{STEM}_{method}_svm_cm_agg_repeated{N_REPEATS}x{N_SPLITS}fold.csv"
    cm_df = pd.DataFrame({
        "matrix": ["TEST_counts", "TEST_row_%", "TRAIN_counts", "TRAIN_row_%"],
        "11": [cm_test_total[0, 0], cm_test_row[0, 0] * 100, cm_train_total[0, 0], cm_train_row[0, 0] * 100],
        "12": [cm_test_total[0, 1], cm_test_row[0, 1] * 100, cm_train_total[0, 1], cm_train_row[0, 1] * 100],
        "21": [cm_test_total[1, 0], cm_test_row[1, 0] * 100, cm_train_total[1, 0], cm_train_row[1, 0] * 100],
        "22": [cm_test_total[1, 1], cm_test_row[1, 1] * 100, cm_train_total[1, 1], cm_train_row[1, 1] * 100],
    })
    saved_cm_csv = safe_to_csv(cm_df, cm_out_csv)
    print(f"\n[Saved] aggregated confusion matrix CSV -> {saved_cm_csv}")
    out_cm_test_tif = method_dir / f"{STEM}_{method}_svm_cm_TEST_agg_rowPct_repeated{N_REPEATS}x{N_SPLITS}fold.tif"
    out_cm_train_tif = method_dir / f"{STEM}_{method}_svm_cm_TRAIN_agg_rowPct_repeated{N_REPEATS}x{N_SPLITS}fold.tif"
    plot_confusion_matrix(cm_test_total, out_cm_test_tif, title=title_TEST, normalize="row", class_names=CLASS_NAMES)
    plot_confusion_matrix(cm_train_total, out_cm_train_tif, title=title_TRAIN, normalize="row", class_names=CLASS_NAMES)
    print(f"[Saved] confusion matrix plot (TEST) -> {out_cm_test_tif}")
    print(f"[Saved] confusion matrix plot (TRAIN) -> {out_cm_train_tif}")

    out_hist_tif = method_dir / f"{STEM}_{method}_svm_overallTESTacc_hist_{n_eval}_evals.tif"
    plot_accuracy_hist(acc_all_test, out_hist_tif, title=f"Overall TEST accuracy histogram ({method}, {n_eval} evals)")
    print(f"[Saved] overall test accuracy histogram -> {out_hist_tif}")

    out_csv = method_dir / f"{STEM}_{method}_svm_repeated{N_REPEATS}x{N_SPLITS}fold_results.csv"
    out_df = pd.DataFrame({
        "eval_id": np.arange(n_eval), "repeat_id": rep_ids, "fold_id": fold_ids,
        "acc_class1_test": acc1_test, "acc_class2_test": acc2_test, "acc_overall_test": acc_all_test,
        "acc_class1_train": acc1_train, "acc_class2_train": acc2_train, "acc_overall_train": acc_all_train,
    })
    saved_csv = safe_to_csv(out_df, out_csv)
    print(f"\n[Saved] CV results CSV -> {saved_csv}")

    med_class2 = float(np.median(acc2_test))
    rep_eval = int(np.argmin(np.abs(acc2_test - med_class2)))
    rep_train_idx, rep_test_idx = splits[rep_eval]
    X_tr_raw = X[rep_train_idx]; X_te_raw = X[rep_test_idx]; y_tr = y[rep_train_idx]
    X_tr, _, mean_rep, var_rep = normalize_by_train_stats(X_tr_raw, X_te_raw, method, y_tr)
    rep_model = train_svm(X_tr, y_tr)
    _, X_all_norm, _, _ = normalize_by_train_stats(X_tr_raw, X, method, y_tr)

    X_new_raw, y_new, X_new_norm = None, None, None
    if NEW_DATA_FILE.exists():
        X_new_raw, y_new = load_external_data(str(NEW_DATA_FILE))
        X_new_norm, new_mean, new_var = normalize_self_by_own_0h(X_new_raw, y_new, method)

    pca, _, _, shared_xlim, shared_ylim = prepare_shared_pca_and_limits(X_tr, X_all_norm, X_new_norm, model=rep_model)
    out_tif_2d = method_dir / f"{STEM}_{method}_svm_repEval_eval{rep_eval}_2D_PCA_acc{acc_all_test[rep_eval]:.2f}.tif"
    plot_representative_split_2d_pca(X_all_norm, y, rep_train_idx, rep_test_idx, rep_model, pca, shared_xlim, shared_ylim, out_tif_2d)
    print(f"[Saved] representative eval plot (2D PCA, shared axis) -> {out_tif_2d}")

    print(f"Representative eval={rep_eval}, repeat={rep_ids[rep_eval]}, fold={fold_ids[rep_eval]}, "
          f"class2_test_acc={acc2_test[rep_eval]:.3f} (median={med_class2:.3f}), "
          f"overall_test_acc={acc_all_test[rep_eval]:.3f}, overall_train_acc={acc_all_train[rep_eval]:.3f}")

    rep_export_dir = export_rep_norm_points(method_dir=method_dir, method=method, rep_eval=rep_eval,
                                            X_all_norm=X_all_norm, y=y,
                                            rep_train_idx=rep_train_idx, rep_test_idx=rep_test_idx)
    export_decision_planes_xyz(method_dir=method_dir, method=method, rep_eval=rep_eval, model=rep_model,
                               X_all_norm=X_all_norm, grid_n=PLANE_GRID_N)
    export_origin_summary_csv(method_dir=method_dir, method=method, rep_eval=rep_eval, model=rep_model,
                              X_all_norm=X_all_norm, y=y, rep_train_idx=rep_train_idx,
                              rep_test_idx=rep_test_idx, grid_n=PLANE_GRID_N)

    std_rep = np.sqrt(np.maximum(var_rep, 0.0))
    stats = {"method": method, "rep_eval": int(rep_eval),
             "train_0h_mean": mean_rep.tolist(), "train_0h_var": var_rep.tolist(), "train_0h_std": std_rep.tolist()}
    stats_path = rep_export_dir / f"{STEM}_{method}_repEval{rep_eval}_train_norm_stats.json"
    stats_path.write_text(json.dumps(stats, indent=2, ensure_ascii=False), encoding="utf-8")
    print(f"[Saved] rep train normalization stats -> {stats_path}")

    if X_new_norm is not None:

        out_new_plot_2d = method_dir / f"{NEW_STEM}_{method}_oldBoundary_repEval{rep_eval}_2D_PCA_points.tif"
        y_new_pred = plot_newdata_on_old_boundary_2d_pca(X_new_norm, y_new, rep_model, pca, shared_xlim, shared_ylim,
                                                         out_new_plot_2d, pc1_label=PC1_LABEL, pc2_label=PC2_LABEL)
        print(f"[Saved] new-data-on-old-boundary plot (2D PCA) -> {out_new_plot_2d}")

        cm_pred_true = pred_true_counts(y_new, y_new_pred)
        out_new_cm = method_dir / f"{NEW_STEM}_{method}_oldBoundary_repEval{rep_eval}_predByTrue_matrix.tif"
        plot_pred_true_matrix(cm_pred_true, out_new_cm, total_n=len(y_new))
        print(f"[Saved] new-data pred-by-true matrix plot -> {out_new_cm}")

        out_new_csv = method_dir / f"{NEW_STEM}_{method}_oldBoundary_repEval{rep_eval}_predictions.csv"
        df_new = pd.DataFrame({"x1_norm": X_new_norm[:, 0], "x2_norm": X_new_norm[:, 1], "x3_norm": X_new_norm[:, 2],
                               "true_label": y_new, "pred_label": y_new_pred})
        safe_to_csv(df_new, out_new_csv)

        out_new_cm_csv = method_dir / f"{NEW_STEM}_{method}_oldBoundary_repEval{rep_eval}_predByTrue_counts.csv"
        df_cm_new = pd.DataFrame(cm_pred_true, index=["pred_1", "pred_2"], columns=["true_1", "true_2"])
        safe_to_csv(df_cm_new, out_new_cm_csv)

        export_origin_summary_csv_new(method_dir=method_dir, method=method, rep_eval=rep_eval, model=rep_model,
                                      axis_ref_X=X_all_norm, X_new_norm=X_new_norm, y_new=y_new,
                                      y_new_pred=y_new_pred, grid_n=PLANE_GRID_N)
    else:
        print(f"[Skip] External data file not found: {NEW_DATA_FILE}")

def main():
    data_path = Path(DATA_FILE)
    if not data_path.exists():
        raise FileNotFoundError(f"File not found: {data_path.resolve()}")
    X, y = load_data(str(data_path))
    method_map = {"meanDiv": OUT_DIR / "norm_meanDiv", "zscore": OUT_DIR / "norm_zscore"}
    for method, method_dir in method_map.items():
        run_one_normalization(X, y, method=method, method_dir=method_dir)

if __name__ == "__main__":
    main()
