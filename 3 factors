def load_data(file_path: str):
    df = pd.read_csv(file_path, header=None)
    if df.shape[1] < N_FEATURES + 1:
        raise ValueError(f"CSV must contain at least {N_FEATURES + 1} columns: x1, x2, x3, label(1/2)")

    X = df.iloc[:, :N_FEATURES].to_numpy(dtype=float)
    y = df.iloc[:, N_FEATURES].to_numpy()

    uniq = np.unique(y)
    if not set(uniq).issubset({1, 2}):
        raise ValueError(f"Labels must be 1 or 2. Detected: {uniq}")

    n1 = np.sum(y == 1)
    n2 = np.sum(y == 2)
    if n1 < N_SPLITS or n2 < N_SPLITS:
        raise ValueError(f"Each class must have at least n_splits={N_SPLITS} samples. Current Class1={n1}, Class2={n2}")

    return X, y

def load_external_data(file_path: str):
    df = pd.read_csv(file_path, header=None)
    if df.shape[1] < N_FEATURES + 1:
        raise ValueError(f"External CSV must contain at least {N_FEATURES + 1} columns: x1, x2, x3, label(1/2)")
    X = df.iloc[:, :N_FEATURES].to_numpy(dtype=float)
    y = df.iloc[:, N_FEATURES].to_numpy()

    uniq = np.unique(y)
    if not set(uniq).issubset({1, 2}):
        raise ValueError(f"External labels must be 1 or 2. Detected: {uniq}")
    return X, y

def train_svm(X_train, y_train):
    model = SVC(kernel='linear', C=100)
    model.fit(X_train, y_train)
    return model

def summarize(arr: np.ndarray, ndigits: int = 3):
    def r(x):
        return float(np.round(x, ndigits))
    return {
        "mean": r(np.mean(arr)),
        "var": r(np.var(arr, ddof=1)),
        "std": r(np.std(arr, ddof=1)),
        "median": r(np.median(arr)),
        "p2.5": r(np.quantile(arr, 0.025)),
        "p97.5": r(np.quantile(arr, 0.975)),
        "min": r(np.min(arr)),
        "max": r(np.max(arr)),
    }

def confusion_2x2_counts(y_true, y_pred):
    y_true = np.asarray(y_true).astype(int) - 1
    y_pred = np.asarray(y_pred).astype(int) - 1
    cm = np.zeros((2, 2), dtype=int)
    for t, p in zip(y_true, y_pred):
        cm[t, p] += 1
    return cm

def pred_true_counts(y_true, y_pred):
    y_true = np.asarray(y_true).astype(int)
    y_pred = np.asarray(y_pred).astype(int)
    cm = np.zeros((2, 2), dtype=int)
    for t, p in zip(y_true, y_pred):
        cm[p - 1, t - 1] += 1
    return cm

