def load_data(file_path: str):
    df = pd.read_csv(file_path, header=None)
    if df.shape[1] < 3:
        raise ValueError("CSV must contain at least 3 columns: x1, x2, label")
    X = df.iloc[:, :2].to_numpy(dtype=float)
    y = df.iloc[:, 2].to_numpy()

    uniq = np.unique(y)
    if not set(uniq).issubset({1, 2}):
        raise ValueError(f"Labels must be 1 or 2; detected: {uniq}")

    n1 = np.sum(y == 1)
    n2 = np.sum(y == 2)
    if n1 < N_SPLITS or n2 < N_SPLITS:
        raise ValueError(f"Each class must have at least n_splits={N_SPLITS} samples; current Class1={n1}, Class2={n2}")

    return X, y

def load_external_data(file_path: str):
    df = pd.read_csv(file_path, header=None)
    if df.shape[1] < 3:
        raise ValueError("External CSV must contain at least 3 columns: x1, x2, label")
    X = df.iloc[:, :2].to_numpy(dtype=float)
    y = df.iloc[:, 2].to_numpy()

    uniq = np.unique(y)
    if not set(uniq).issubset({1, 2}):
        raise ValueError(f"External labels must be 1 or 2; detected: {uniq}")

    return X, y

def train_svm(X_train, y_train):
    model = SVC(kernel='linear', C=100)
    model.fit(X_train, y_train)
    return model

def summarize(arr: np.ndarray, ndigits: int = 3):
    def r(x):
        return float(np.round(x, ndigits))
    return {
        "mean": r(np.mean(arr)),
        "var": r(np.var(arr, ddof=1)),
        "std": r(np.std(arr, ddof=1)),
        "median": r(np.median(arr)),
        "p2.5": r(np.quantile(arr, 0.025)),
        "p97.5": r(np.quantile(arr, 0.975)),
        "min": r(np.min(arr)),
        "max": r(np.max(arr)),
    }

def bootstrap_ci(arr: np.ndarray, n_boot=5000, seed=0, stat="mean"):
    rng = np.random.default_rng(seed)
    arr = np.asarray(arr, dtype=float)
    n = arr.size

    if stat == "mean":
        stat_func = np.mean
    elif stat == "median":
        stat_func = np.median
    else:
        raise ValueError("stat only supports 'mean' or 'median'")

    point = float(stat_func(arr))
    boot_stats = np.empty(n_boot, dtype=float)
    for b in range(n_boot):
        sample = rng.choice(arr, size=n, replace=True)
        boot_stats[b] = stat_func(sample)

    lo = float(np.quantile(boot_stats, 0.025))
    hi = float(np.quantile(boot_stats, 0.975))
    return point, (lo, hi), boot_stats

def ci_width_metrics(point, ci, chance=0.5):
    lo, hi = ci
    W = hi - lo
    h = W / 2.0
    delta = point - chance
    r = np.inf if delta <= 0 else (h / delta)
    return W, h, delta, r, (lo > chance), (hi > chance)

def confusion_2x2_counts(y_true, y_pred):
    y_true = np.asarray(y_true).astype(int) - 1
    y_pred = np.asarray(y_pred).astype(int) - 1
    cm = np.zeros((2, 2), dtype=int)
    for t, p in zip(y_true, y_pred):
        cm[t, p] += 1
    return cm

def pred_true_counts(y_true, y_pred):
    y_true = np.asarray(y_true).astype(int)
    y_pred = np.asarray(y_pred).astype(int)
    cm = np.zeros((2, 2), dtype=int)
    for t, p in zip(y_true, y_pred):
        cm[p - 1, t - 1] += 1
    return cm

def plot_confusion_matrix(
    cm_counts,
    out_tif: Path,
    title="Aggregated Confusion Matrix",
    normalize="row",
    cmap="GnBu",
    class_names=None,
    tick_font=32,
    title_font=32,
    annot_font=28,
    cbar_font=32
):
    if class_names is None:
        class_names = ["1", "2"]

    cm_counts = np.asarray(cm_counts, dtype=float)

    if normalize == "row":
        row_sum = cm_counts.sum(axis=1, keepdims=True)
        cm_show = np.divide(cm_counts, row_sum, out=np.zeros_like(cm_counts), where=row_sum != 0) * 100.0
        show_is_percent = True
        vmin, vmax = 0.0, 100.0
    else:
        cm_show = cm_counts
        show_is_percent = False
        vmin, vmax = float(np.min(cm_show)), float(np.max(cm_show))

    fig = plt.figure(figsize=(9, 7), dpi=300)
    ax = plt.gca()

    im = ax.imshow(cm_show, cmap=cmap, vmin=vmin, vmax=vmax, alpha=0.6)

    ax.set_title(title, fontsize=title_font, pad=12)
    ax.set_xlabel("Predicted label", fontsize=tick_font, labelpad=8)
    ax.set_ylabel("True label", fontsize=tick_font, labelpad=8)

    ax.set_xticks([0, 1])
    ax.set_yticks([0, 1])

    ax.set_xticklabels(class_names, fontsize=tick_font)
    ax.set_yticklabels(class_names, fontsize=tick_font)

    ax.set_xticks(np.arange(-.5, 2, 1), minor=True)
    ax.set_yticks(np.arange(-.5, 2, 1), minor=True)
    ax.grid(which="minor", color="white", linestyle="-", linewidth=2)
    ax.tick_params(which="minor", bottom=False, left=False)

    for i in range(2):
        for j in range(2):
            cnt = int(cm_counts[i, j])
            if show_is_percent:
                txt = f"{cm_show[i, j]:.1f}%\n($\\mathit{{n}}$={cnt})"
            else:
                txt = f"($\\mathit{{n}}$={cnt})"
            ax.text(j, i, txt, ha="center", va="center", fontsize=annot_font)

    cbar = plt.colorbar(im, ax=ax, fraction=0.046, pad=0.04)
    cbar.set_label("Percentage (%)", fontsize=cbar_font, rotation=270, labelpad=18)
    cbar.ax.tick_params(labelsize=cbar_font)

    plt.tight_layout(pad=0.6)
    fig.savefig(out_tif, format="tif", bbox_inches="tight")
    plt.close(fig)

